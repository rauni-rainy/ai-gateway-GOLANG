# The port the HTTP server will listen on (default: 8080)
PORT=8080

# The connection string for PostgreSQL (REQUIRED)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:secret@localhost:5432/aigateway?sslmode=disable

# The connection string for Redis (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Groq API Key for making calls to Groq models
GROQ_KEY=your_groq_api_key_here

# Gemini API Key for making calls to Google Gemini models
GEMINI_KEY=your_gemini_api_key_here

# Default Rate Limit requests per second per IP (default: 10)
DEFAULT_RPS=10

# Time to live for cached responses in seconds (default: 3600)
CACHE_TTL_SECONDS=3600

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info
